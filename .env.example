APP_NAME=ATLAAS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use `reverb` for Compass View live updates (run `php artisan reverb:start`). `log` or `null` disables live WebSockets.
BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail — log driver (dev) or SMTP with app password (Gmail, Workspace, M365)
# ---------------------------------------------------------------------------
MAIL_MAILER=log

# SMTP host (examples: smtp.gmail.com, smtp.office365.com, your relay)
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

# Login: usually the full mailbox address + app password (not your normal password)
MAIL_USERNAME=
MAIL_PASSWORD=

# From header (often same as MAIL_USERNAME for Gmail/Workspace)
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Encryption — pick ONE style:
# Option A: MAIL_SCHEME (Symfony mailer): smtp = STARTTLS, smtps = SSL (implicit)
# MAIL_SCHEME=smtp
# MAIL_SCHEME=smtps

# Option B: MAIL_ENCRYPTION (friendly aliases; ignored if MAIL_SCHEME is set)
# MAIL_ENCRYPTION=tls
# MAIL_ENCRYPTION=ssl

# Typical combinations:
#   TLS (STARTTLS): MAIL_SCHEME=smtp  MAIL_PORT=587
#   SSL:            MAIL_SCHEME=smtps MAIL_PORT=465

# Optional SMTP timeout in seconds
# MAIL_TIMEOUT=30

# Optional: full DSN overrides host/port/scheme/user/pass if set
# MAIL_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSockets — Compass View). Set BROADCAST_CONNECTION=reverb when using.
REVERB_APP_ID=atlaas
REVERB_APP_KEY=atlaas-key
REVERB_APP_SECRET=change-this-in-production
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Google OAuth (Workspace / consumer) — must match Google Cloud Console redirect URI
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# OpenAI-compatible API (student assistant, toolkit, safety flows)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Student chat rich responses (images). See config/atlas.php — wikimedia (default), unsplash, or pexels.
# IMAGE_SOURCE=wikimedia
# UNSPLASH_ACCESS_KEY=   # config/services.php services.unsplash.access_key
# PEXELS_API_KEY=        # config/services.php services.pexels.api_key

# Text-to-speech (Kokoro). See phases/Phase3c_TTS_Kokoro.md — Speak button on student chat when true.
TTS_ENABLED=false
TTS_KOKORO_URL=http://localhost:8880
TTS_DEFAULT_VOICE=af_heart
TTS_DEFAULT_SPEED=0.9

# Laravel Scout (Discover search). Use `meilisearch` in production with Meilisearch running.
# Local dev: `collection` — Discover still works; cross-district text search can fall back to SQL.
SCOUT_DRIVER=collection
SCOUT_QUEUE=false

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=
