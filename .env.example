# =============================================================================
# ATLAAS — copy this file to `.env` and adjust values.
#   copy .env.example .env   (Windows / macOS / Linux)
# Then: php artisan key:generate
# =============================================================================

# --- Application -------------------------------------------------------------
APP_NAME=ATLAAS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Local `php artisan serve`: http://127.0.0.1:8000
# XAMPP/Apache subfolder: e.g. http://localhost/atlaas/public — must match your vhost
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL / MariaDB — recommended) ------------------------------
# Create an empty database first, e.g.:
#   mysql -u root -e "CREATE DATABASE atlaas CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
# XAMPP/WAMP default is often user root with empty password.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=atlaas
DB_USERNAME=root
DB_PASSWORD=

# Optional: Unix socket instead of TCP (some local stacks)
# DB_SOCKET=

# Optional: SQLite instead (no MySQL) — set DB_CONNECTION=sqlite and comment MySQL lines above
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# --- Demo login seeding (TestDataSeeder) -------------------------------------
# When false (default), `php artisan db:seed` does NOT create admin@demo.test /
# teacher@demo.test / student@demo.test with the known password — safer for production
# and re-seeds. Roles, permissions, and built-in toolkit tools still seed.
# Set true only on trusted local/staging when you want those accounts.
SEED_DEMO_ACCOUNTS=false

# --- Session (database — works with MySQL only) ------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Redis (required for defaults below: cache + queues + rich-response image cache) ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Cache & queues ----------------------------------------------------------
# Default is Redis for both so they stay aligned: Horizon expects redis queues, and
# Wikimedia/Unsplash image resolution (ImageService) uses Cache::remember — redis avoids
# hammering MySQL with 24h image metadata entries.
# Without Redis: set CACHE_STORE=database and QUEUE_CONNECTION=database (then php artisan queue:work), or QUEUE_CONNECTION=sync for in-process jobs only.
CACHE_STORE=redis
QUEUE_CONNECTION=redis

MEMCACHED_HOST=127.0.0.1

# --- Broadcasting ------------------------------------------------------------
# `reverb` for Compass View live updates (php artisan reverb:start). `log` = no WebSockets.
BROADCAST_CONNECTION=log

# --- Files -------------------------------------------------------------------
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# Mail — log (dev) or SMTP with app password (Gmail, Workspace, M365)
# ---------------------------------------------------------------------------
MAIL_MAILER=log

MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# TLS (STARTTLS): MAIL_SCHEME=smtp  MAIL_PORT=587
# SSL:            MAIL_SCHEME=smtps MAIL_PORT=465
# MAIL_SCHEME=smtp
# MAIL_URL=

# --- Frontend (Vite) ---------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# --- Laravel Reverb (WebSockets — Compass View) -----------------------------
# Set BROADCAST_CONNECTION=reverb when using. Match VITE_* to what the browser uses.
# Replace REVERB_APP_SECRET before production — README: Str::random(32) via tinker or openssl rand -hex 32
REVERB_APP_ID=atlaas
REVERB_APP_KEY=atlaas-key
REVERB_APP_SECRET=change-this-in-production
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Google OAuth (optional) -------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- OpenAI-compatible API (student chat, toolkit, safety) -------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Rich chat images (optional) — config/atlaas.php + config/services.php ----
IMAGE_SOURCE=wikimedia
# UNSPLASH_ACCESS_KEY=
# PEXELS_API_KEY=

# --- Text-to-speech (optional) — needs Kokoro server -------------------------
# https://github.com/remsky/kokoro-fastapi — phases/Phase3c_TTS_Kokoro.md
TTS_ENABLED=false
TTS_KOKORO_URL=http://localhost:8880
TTS_DEFAULT_VOICE=af_heart
TTS_DEFAULT_SPEED=0.9

# --- Laravel Scout / Discover ------------------------------------------------
# `collection` = no Meilisearch required locally. Production: often meilisearch.
SCOUT_DRIVER=collection
SCOUT_QUEUE=false
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# --- AWS (optional — S3, etc.) -----------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
